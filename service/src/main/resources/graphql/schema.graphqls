enum TeamCode {
    t001
    t002
    t003
    t004
    t005
    t006
}

enum AvailableChannels {
     All
     Adviser
     EmployeeApp
}


"""
Offer fields exposed to GraphQL
"""
type Offer {
    offerCode: String
    productCode: String
    basePrice: Float
    calculatedPrice: Float
    discountApplied: Float
}

type Query {
    qualifyingOffers(teamCode: TeamCode!, channel: AvailableChannels!): [Offer!]!
}